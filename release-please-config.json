{
    "release-type": "simple",
    "packages": {
        ".": {
            "package-name": ""
        }
    },
    "extra-files": [
        {
            "type": "json",
            "path": "package.json",
            "jsonpath": "$.version"
        },
        {
            "type": "json",
            "path": "package-lock.json",
            "jsonpath": "$.version"
        },
        {
            "type": "json",
            "path": "package-lock.json",
            "jsonpath": "$['packages']['']['version']"
        }
        
    ],
    "bump-minor-pre-major": true,
    "bump-patch-for-minor-pre-major": true
}